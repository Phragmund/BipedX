<mujoco model="FootWheel">
    <compiler angle="radian" meshdir="/home/phragmund/FootWheel/meshes/" />
    <size njmax="500" nconmax="100" />
    <default>
  <geom 
    friction="0.9 0.09 0.009"
    solimp="0.9 0.95 0.001"  
    solref="0.02 1"          
    margin="0.01"          
    condim="6"               
  />
</default>

